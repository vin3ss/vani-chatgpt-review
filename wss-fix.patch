+// ─── Single upgrade router (2026-06-08 P0 FIX) ───────────────────────────────
+// Replaces the per-WSS auto-installed listeners that were aborting each other
+// with HTTP 400. We listen to `upgrade` ONCE here, parse the path, and
+// dispatch to the matching WSS via handleUpgrade. Any unknown path is
+// destroyed without writing 400 back (so Vobiz sees a TCP RST it understands,
+// not a malformed HTTP response).
+server.on('upgrade', (req, socket, head) => {
+  let pathname;
+  try {
+    pathname = new URL(req.url, `http://${req.headers.host}`).pathname;
+  } catch (_) {
+    socket.destroy();
+    return;
+  }
+
+  if (pathname === '/call/outbound-fast') {
+    wssOutboundFast.handleUpgrade(req, socket, head, (ws) => {
+      wssOutboundFast.emit('connection', ws, req);
+    });
+  } else if (pathname === '/call/outbound') {
+    wssOutbound.handleUpgrade(req, socket, head, (ws) => {
+      wssOutbound.emit('connection', ws, req);
+    });
+  } else {
+    console.warn(`[VaniOut] upgrade for unknown path=${pathname} — destroying socket`);
+    socket.destroy();
+  }
+});
+
